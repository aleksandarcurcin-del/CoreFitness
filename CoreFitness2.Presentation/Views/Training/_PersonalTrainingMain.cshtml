<section class="personal-training-section">
    <div class="container">
        <div class="personal-training-cards">

            <div class="personal-training-card">
                <img src="~/assets/images/personal-training-1.jpg" alt="One to one coaching" class="personal-training-image" />
                <div class="personal-training-body">
                    <p class="personal-training-category">ONE TO ONE COACHING</p>
                    <h2>Personalized sessions built around you</h2>
                    <p class="personal-training-description">
                        Work one-on-one with a dedicated trainer who tailors every session to your
                        body, your goals, and your experience level. Perfect for technique, accountability,
                        and measurable progress.
                    </p>

                    <div class="personal-training-details">
                        <div><strong>Focus:</strong> Strength, fat loss, confidence, performance</div>
                        <div><strong>Format:</strong> Private 1-on-1 sessions</div>
                        <div><strong>Availability:</strong> Flexible booking</div>
                    </div>

                    <a asp-controller="Support" asp-action="Index" class="btn btn--primary personal-training-btn">
                        <span class="btn__text">Book Consultation</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

            <div class="personal-training-card">
                <img src="~/assets/images/personal-training-2.jpg" alt="Strength and performance coaching" class="personal-training-image" />
                <div class="personal-training-body">
                    <p class="personal-training-category">STRENGTH & PERFORMANCE</p>
                    <h2>Improve strength, movement, and athletic performance</h2>
                    <p class="personal-training-description">
                        Designed for members who want structured progression, better lifting technique,
                        improved mobility, and performance-driven programming.
                    </p>

                    <div class="personal-training-details">
                        <div><strong>Focus:</strong> Technique, progression, performance</div>
                        <div><strong>Format:</strong> Individual coaching plans</div>
                        <div><strong>Level:</strong> Beginner to advanced</div>
                    </div>

                    <a asp-controller="Support" asp-action="Index" class="btn btn--primary personal-training-btn">
                        <span class="btn__text">Book Consultation</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

            <div class="personal-training-card">
                <img src="~/assets/images/personal-training-3.jpg" alt="Lifestyle and wellness coaching" class="personal-training-image" />
                <div class="personal-training-body">
                    <p class="personal-training-category">LIFESTYLE SUPPORT</p>
                    <h2>Build healthy habits that last</h2>
                    <p class="personal-training-description">
                        Personal training is not only about workouts. Our coaches help you create a
                        realistic routine with motivation, structure, and long-term sustainability.
                    </p>

                    <div class="personal-training-details">
                        <div><strong>Focus:</strong> Consistency, confidence, everyday fitness</div>
                        <div><strong>Support:</strong> Guidance and accountability</div>
                        <div><strong>Goal:</strong> Long-term lifestyle change</div>
                    </div>

                    <a asp-controller="Support" asp-action="Index" class="btn btn--primary personal-training-btn">
                        <span class="btn__text">Book Consultation</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>