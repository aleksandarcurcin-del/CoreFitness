@model CoreFitness2.Presentation.ViewModels.Account.SignInViewModel

@{
    ViewData["Title"] = "Sign In";
}

<section class="sign-in">
    <div class="container">
        <div class="sign-up-bg-color">
            <div class="sign-up-flex">
                <h1>Welcome Back!</h1>
                <p>
                    Log in to continue your fitness journey, access your training plan,
                    and keep track of your progress.
                </p>

                <div class="card__divider"></div>

                <div class="sign-up-links">
                    <button class="social-btn" type="button">
                        <img src="~/assets/images/google.svg" alt="Google">
                    </button>
                    <button class="social-btn" type="button">
                        <img src="~/assets/images/facebook.svg" alt="Facebook">
                    </button>
                    <button class="social-btn" type="button">
                        <img src="~/assets/images/github.svg" alt="GitHub">
                    </button>
                </div>

                <div class="card__divider divider-text">
                    <span>OR CONTINUE WITH</span>
                </div>

                <form asp-action="Signin" method="post" class="form">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="field">
                        <label asp-for="Email">Email Address</label>
                        <input asp-for="Email" placeholder="Enter Email Address" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Password">Password</label>
                        <input asp-for="Password" type="password" placeholder="Enter Password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="sign-up-lower">
                        <button class="btn btn--primary btn--full" type="submit">
                            <div class="continue-btn">Continue</div>
                            <span class="btn-chev" aria-hidden="true">›</span>
                        </button>

                        <label class="check">
                            <input type="checkbox" name="terms">
                            <span class="check__box" aria-hidden="true"></span>
                            <span class="check__text">Accept user terms and conditions</span>
                        </label>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

            