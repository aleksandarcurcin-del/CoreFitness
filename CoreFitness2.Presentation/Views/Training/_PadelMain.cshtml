<section class="padel-section">
    <div class="container">
        <div class="padel-cards">

            <div class="padel-card">
                <img src="~/assets/images/padel-1.jpg" alt="Padel coaching session" class="padel-image" />
                <div class="padel-body">
                    <p class="padel-category">COACHING & TECHNIQUE</p>
                    <h2>Improve your game with structured coaching</h2>
                    <p class="padel-description">
                        Learn positioning, timing, shot selection, and movement patterns through
                        guided coaching sessions designed to help you build confidence and improve
                        your overall game.
                    </p>

                    <div class="padel-details">
                        <div><strong>Focus:</strong> Technique, control, movement</div>
                        <div><strong>Format:</strong> Guided coaching sessions</div>
                        <div><strong>Level:</strong> Beginner to intermediate</div>
                    </div>

                    <a asp-controller="Support" asp-action="Index" class="btn btn--primary btn--fit">
                        <span class="btn__text">Book a Session</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

            <div class="padel-card">
                <img src="~/assets/images/padel-2.jpg" alt="Padel match play" class="padel-image" />
                <div class="padel-body">
                    <p class="padel-category">MATCH PLAY</p>
                    <h2>Play competitive and social matches</h2>
                    <p class="padel-description">
                        Join match sessions where you can test your skills, build match awareness,
                        and enjoy the social side of padel in a motivating CoreFitness atmosphere.
                    </p>

                    <div class="padel-details">
                        <div><strong>Focus:</strong> Match rhythm, tactics, teamwork</div>
                        <div><strong>Format:</strong> Social and competitive play</div>
                        <div><strong>Benefit:</strong> Improve through real game situations</div>
                    </div>

                    <a asp-controller="Support" asp-action="Index" class="btn btn--primary btn--fit">
                        <span class="btn__text">Find Match Times</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

            <div class="padel-card">
                <img src="~/assets/images/padel-3.jpg" alt="Padel community" class="padel-image" />
                <div class="padel-body">
                    <p class="padel-category">COMMUNITY & ENERGY</p>
                    <h2>A sport built around community and progression</h2>
                    <p class="padel-description">
                        Padel is more than just training. It is a social, accessible, and highly
                        engaging way to stay active while meeting others who enjoy the same energy,
                        challenge, and fun.
                    </p>

                    <div class="padel-details">
                        <div><strong>Focus:</strong> Community, consistency, enjoyment</div>
                        <div><strong>Atmosphere:</strong> Social, modern, supportive</div>
                        <div><strong>Perfect for:</strong> Members who want movement with variety</div>
                    </div>

                    <a asp-controller="Membership" asp-action="Index" class="btn btn--primary btn--fit">
                        <span class="btn__text">Explore Memberships</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>