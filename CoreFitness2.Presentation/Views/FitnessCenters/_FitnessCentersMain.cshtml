<section class="fitness-centers-section">
    <div class="container">
        <div class="fitness-centers-grid">

            <div class="fitness-center-card">
                <img src="~/assets/images/gym1.jpg" alt="CoreFitness Helsingborg" class="fitness-center-image" />
                <div class="fitness-center-body">
                    <h2>CoreFitness Helsingborg</h2>
                    <p class="fitness-center-address">Drottninggatan 24, Helsingborg</p>
                    <p>
                        A modern city-center facility with open gym spaces, strength equipment,
                        cardio areas, and group training studios.
                    </p>

                    <div class="fitness-center-details">
                        <div><strong>Opening hours:</strong> 05:00 – 23:00</div>
                        <div><strong>Facilities:</strong> Gym, Group Classes, PT, Sauna</div>
                    </div>

                    <a asp-controller="Support" asp-action="Index" class="btn btn--primary fitness-btn">
                        <span class="btn__text">Contact Center</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

            <div class="fitness-center-card">
                <img src="~/assets/images/gym2.jpg" alt="CoreFitness Malmö" class="fitness-center-image" />
                <div class="fitness-center-body">
                    <h2>CoreFitness Malmö</h2>
                    <p class="fitness-center-address">Södra Förstadsgatan 51, Malmö</p>
                    <p>
                        A larger performance-focused gym with premium training zones,
                        recovery areas, and functional fitness classes.
                    </p>

                    <div class="fitness-center-details">
                        <div><strong>Opening hours:</strong> 05:00 – 23:00</div>
                        <div><strong>Facilities:</strong> Gym, Functional Zone, PT, Recovery</div>
                    </div>

                    <a asp-controller="Support" asp-action="Index" class="btn btn--primary fitness-btn">
                        <span class="btn__text">Contact Center</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

            <div class="fitness-center-card">
                <img src="~/assets/images/gym3.jpg" alt="CoreFitness Stockholm" class="fitness-center-image" />
                <div class="fitness-center-body">
                    <h2>CoreFitness Lund</h2>
                    <p class="fitness-center-address">Drottninggatan 118, Stockholm</p>
                    <p>
                        A welcoming training center with community-focused classes,
                        beginner-friendly support, and premium workout equipment.
                    </p>

                    <div class="fitness-center-details">
                        <div><strong>Opening hours:</strong> 06:00 – 22:00</div>
                        <div><strong>Facilities:</strong> Gym, Group Classes, PT</div>
                    </div>

                    <a asp-controller="Support" asp-action="Index" class="btn btn--primary fitness-btn">
                        <span class="btn__text">Contact Center</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>