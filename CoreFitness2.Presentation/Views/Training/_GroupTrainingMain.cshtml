<section class="group-training-section">
    <div class="container">
        <div class="group-training-cards">

            <div class="group-training-card">
                <img src="~/assets/images/group-training-1.jpg" alt="Strength classes" class="group-training-image" />
                <div class="group-training-body">
                    <p class="group-training-category">STRENGTH CLASSES</p>
                    <h2>Build strength in a motivating group environment</h2>
                    <p class="group-training-description">
                        Join structured strength-based classes where expert instructors guide you
                        through safe, effective workouts designed to improve technique, power,
                        and consistency.
                    </p>

                    <div class="group-training-details">
                        <div><strong>Focus:</strong> Strength, endurance, progression</div>
                        <div><strong>Format:</strong> Instructor-led classes</div>
                        <div><strong>Level:</strong> Beginner to advanced</div>
                    </div>

                    <a asp-controller="Classes" asp-action="Index" class="btn btn--primary btn--fit">
                        <span class="btn__text">See Classes</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

            <div class="group-training-card">
                <img src="~/assets/images/group-training-2.jpg" alt="High energy cardio classes" class="group-training-image" />
                <div class="group-training-body">
                    <p class="group-training-category">CARDIO & CONDITIONING</p>
                    <h2>High-energy sessions that keep you moving</h2>
                    <p class="group-training-description">
                        Improve fitness, burn energy, and stay challenged through dynamic workouts
                        built around movement, intensity, and teamwork.
                    </p>

                    <div class="group-training-details">
                        <div><strong>Focus:</strong> Cardio, conditioning, stamina</div>
                        <div><strong>Format:</strong> Fast-paced group sessions</div>
                        <div><strong>Benefit:</strong> Motivation through shared effort</div>
                    </div>

                    <a asp-controller="Classes" asp-action="Index" class="btn btn--primary btn--fit">
                        <span class="btn__text">Join a Session</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

            <div class="group-training-card">
                <img src="~/assets/images/group-training-3.jpg" alt="Community based training" class="group-training-image" />
                <div class="group-training-body">
                    <p class="group-training-category">COMMUNITY & SUPPORT</p>
                    <h2>Train with others and stay accountable</h2>
                    <p class="group-training-description">
                        Group training helps you stay consistent by combining expert coaching
                        with a social, supportive setting where you can push yourself together
                        with others.
                    </p>

                    <div class="group-training-details">
                        <div><strong>Focus:</strong> Community, routine, accountability</div>
                        <div><strong>Atmosphere:</strong> Encouraging and energetic</div>
                        <div><strong>Perfect for:</strong> Members who want structure and motivation</div>
                    </div>

                    <a asp-controller="Membership" asp-action="Index" class="btn btn--primary btn--fit">
                        <span class="btn__text">Explore Memberships</span>
                        <span class="btn__icon">›</span>
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>