@model CoreFitness2.Presentation.ViewModels.Profile.ProfileViewModel

<div class="about-me-right">
    <h2 class="card__title">About Me</h2>
    <div class="card__divider"></div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="success-message">
            @TempData["SuccessMessage"]
        </div>
    }

    <form asp-action="Index" method="post" class="form" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-grid">
            <div class="field">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName" type="text" placeholder="Enter First Name">
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="field">
                <label asp-for="LastName"></label>
                <input asp-for="LastName" type="text" placeholder="Enter Last Name">
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="field field--full">
                <label asp-for="Email">Email Address <span aria-hidden="true">*</span></label>
                <input asp-for="Email" type="email" readonly>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="field field--full">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" type="tel" placeholder="Enter Phone Number">
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
        </div>

        <div class="card__divider"></div>

        <div class="field">
            <label asp-for="ProfileImage">Profile Image</label>
            <div class="upload">
                <input asp-for="ProfileImage" class="upload__input" type="file" accept="image/*">
                <span class="upload__fake" aria-hidden="true">Upload Profile Image</span>
                <span class="upload__btn" aria-hidden="true">Browse</span>
            </div>
            <span asp-validation-for="ProfileImage" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button class="btn btn--primary" type="submit">
                Save <span aria-hidden="true">›</span>
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}